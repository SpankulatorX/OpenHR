@page "/integrationer/oversikt"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Infrastructure.Integrations.Framework
@using RegionHR.IntegrationHub.Framework
@using RegionHR.IntegrationHub.Infrastructure
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject IIntegrationRunLogStore RunLog
@inject IntegrationJobRunner Runner
@inject ISftpTransport Transport
@inject AuthenticationStateProvider AuthState

<PageTitle>OpenHR - Integrationsöversikt</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/integrationer" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Integrationsöversikt</MudText>
<MudText Typo="Typo.body1" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Alla @IntegrationRegistry.Alla.Count integrationer mot regionens personalstöds-arkitektur, deras riktning, transport,
    motpart, frekvens och senaste körning. Körningar genererar filer och lägger dem i drop-katalogen via
    integrationsramverket.
</MudText>

<MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-4">
    <strong>Ramverket kräver inget betalt avtal.</strong> Filer genereras och droppas lokalt av
    <em>@Transport.Namn</em>. Skarp transport till integrationsmotorn Health Connect (SFTP/WS/REST) är
    <strong>config-ready</strong> — den aktiveras genom att fylla i endpoint/nycklar och koppla in den
    skarpa transportadaptern, utan att röra jobbrunner eller denna vy.
</MudAlert>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3"><MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.caption">Integrationer</MudText>
            <MudText Typo="Typo.h5" Style="font-weight:700;">@_rader.Count</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.caption">Utgående</MudText>
            <MudText Typo="Typo.h5" Style="font-weight:700;">@IntegrationRegistry.Utgaende.Count()</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.caption">Inkommande</MudText>
            <MudText Typo="Typo.h5" Style="font-weight:700;">@IntegrationRegistry.Inkommande.Count()</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.caption">Senaste körning misslyckad</MudText>
            <MudText Typo="Typo.h5" Style="font-weight:700;" Color="@(_antalFel > 0 ? Color.Error : Color.Default)">@_antalFel</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.subtitle2">Transport:</MudText>
            <MudText Typo="Typo.body2">@Transport.Namn</MudText>
            <MudChip T="string" Size="Size.Small" Color="@(Transport.ArSkarp ? Color.Success : Color.Warning)">
                @(Transport.ArSkarp ? "Skarp" : "Lokal fil-drop")
            </MudChip>
            <MudChip T="string" Size="Size.Small" Color="@(_transportOk ? Color.Success : Color.Error)">
                @(_transportOk ? "Nåbar" : "Ej nåbar")
            </MudChip>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.subtitle2">Outbox:</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Info">Väntande @_outboxPending</MudChip>
            <MudChip T="string" Size="Size.Small" Color="@(_outboxFailed > 0 ? Color.Error : Color.Default)">Misslyckade @_outboxFailed</MudChip>
            <MudChip T="string" Size="Size.Small" Color="@(_outboxDead > 0 ? Color.Error : Color.Default)">Dead-letter @_outboxDead</MudChip>
        </MudStack>
    </MudPaper>

    @if (_status is not null)
    {
        <MudAlert Severity="@_statusSeverity" Variant="Variant.Text" Class="mb-3" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _status = null)">@_status</MudAlert>
    }

    <MudTable Items="_rader" Hover="true" Dense="true" Elevation="2" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Integration</MudTh>
            <MudTh>Riktning</MudTh>
            <MudTh>Transport</MudTh>
            <MudTh>Motpart</MudTh>
            <MudTh>Frekvens</MudTh>
            <MudTh>Senaste körning</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="text-align:right;">Poster</MudTh>
            <MudTh>Åtgärd</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Integration">
                <MudText Typo="Typo.body2" Style="font-weight:600;">@context.Def.Namn</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                    @context.Def.Format@(context.Def.ViaHealthConnect ? " · via Health Connect" : "")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Riktning">@RiktningText(context.Def.Riktning)</MudTd>
            <MudTd DataLabel="Transport">@TransportText(context.Def.Transport)</MudTd>
            <MudTd DataLabel="Motpart">@context.Def.Motpart</MudTd>
            <MudTd DataLabel="Frekvens">@context.Def.Frekvens</MudTd>
            <MudTd DataLabel="Senaste körning">
                @if (context.Senaste is { } r)
                {
                    <MudText Typo="Typo.body2">@r.StartadUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@r.UtlostAv</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Aldrig körd</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Status">
@if (context.Senaste is { } s)
                {
                    @if (s.Fel is not null || s.Anmarkning is not null)
                    {
                        <MudTooltip Text="@(s.Fel ?? s.Anmarkning)">
                            <MudChip T="string" Size="Size.Small" Color="@StatusColor(s.Status)">@StatusText(s.Status)</MudChip>
                        </MudTooltip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="@StatusColor(s.Status)">@StatusText(s.Status)</MudChip>
                    }
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Ej körd</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Poster" Style="text-align:right;">@(context.Senaste?.AntalPoster.ToString() ?? "—")</MudTd>
            <MudTd DataLabel="Åtgärd">
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           Disabled="@_running"
                           OnClick="@(() => KorOm(context.Def))">
                    @(Runner.HarKorbartJobb(context.Def.Key) ? "Kör" : "Kör (loggas)")
                </MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private bool _loading = true;
    private bool _running;
    private bool _transportOk;
    private int _antalFel;
    private int _outboxPending;
    private int _outboxFailed;
    private int _outboxDead;
    private string? _status;
    private Severity _statusSeverity = Severity.Success;
    private List<Rad> _rader = [];

    protected override async Task OnInitializedAsync() => await Ladda();

    private async Task Ladda()
    {
        _transportOk = await Transport.TestaAnslutningAsync();

        var senaste = (await RunLog.HamtaSenastePerIntegrationAsync())
            .ToDictionary(r => r.IntegrationKey, StringComparer.OrdinalIgnoreCase);

        _rader = IntegrationRegistry.Alla
            .Select(d => new Rad(d, senaste.GetValueOrDefault(d.Key)))
            .ToList();

        _antalFel = _rader.Count(r => r.Senaste?.Status == IntegrationRunStatus.Misslyckad);

        await using var db = await DbFactory.CreateDbContextAsync();
        var outbox = await db.OutboxMessages
            .GroupBy(m => m.Status)
            .Select(g => new { g.Key, Antal = g.Count() })
            .ToListAsync();
        _outboxPending = outbox.Where(o => o.Key is OutboxStatus.Pending or OutboxStatus.Processing).Sum(o => o.Antal);
        _outboxFailed = outbox.Where(o => o.Key == OutboxStatus.Failed).Sum(o => o.Antal);
        _outboxDead = outbox.Where(o => o.Key == OutboxStatus.DeadLetter).Sum(o => o.Antal);

        _loading = false;
    }

    private async Task KorOm(IntegrationDefinition def)
    {
        _running = true;
        _status = null;
        try
        {
            var utlostAv = $"Manuell ({await AktuellAnvandare()})";
            var r = await Runner.KorAsync(def.Key, utlostAv);
            (_status, _statusSeverity) = r.Status switch
            {
                IntegrationRunStatus.Lyckad =>
                    ($"{def.Namn}: {r.AntalPoster} poster levererade till {r.Plats}.", Severity.Success),
                IntegrationRunStatus.SaknarJobb =>
                    ($"{def.Namn}: {r.Anmarkning}", Severity.Info),
                _ =>
                    ($"{def.Namn} misslyckades: {r.Fel}", Severity.Error)
            };
            await Ladda();
        }
        catch (Exception ex)
        {
            _status = $"Kunde inte köra {def.Namn}: {ex.Message}";
            _statusSeverity = Severity.Error;
        }
        finally
        {
            _running = false;
        }
    }

    private async Task<string> AktuellAnvandare()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        return auth.User.Identity?.Name is { Length: > 0 } n ? n : "okänd";
    }

    private static string RiktningText(IntegrationDirection d) => d switch
    {
        IntegrationDirection.Utgaende => "Ut",
        IntegrationDirection.Inkommande => "In",
        _ => "Ut/In"
    };

    private static string TransportText(IntegrationTransport t) => t switch
    {
        IntegrationTransport.Fil => "Fil (SFTP)",
        IntegrationTransport.Webbtjanst => "Webbtjänst (WS)",
        _ => "REST-API"
    };

    private static string StatusText(IntegrationRunStatus s) => s switch
    {
        IntegrationRunStatus.Lyckad => "Lyckad",
        IntegrationRunStatus.Misslyckad => "Misslyckad",
        _ => "Saknar jobb"
    };

    private static Color StatusColor(IntegrationRunStatus s) => s switch
    {
        IntegrationRunStatus.Lyckad => Color.Success,
        IntegrationRunStatus.Misslyckad => Color.Error,
        _ => Color.Default
    };

    private sealed record Rad(IntegrationDefinition Def, IntegrationKorningsResultat? Senaste);
}
