@page "/lon/korning/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Payroll.Domain
@using RegionHR.Infrastructure.Payroll
@inject PayrollBatchService Batch
@inject NavigationManager Nav

<PageTitle>OpenHR - Ny lönekörning</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="/lon/korningar" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Ny lönekörning</MudText>

@if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }

@if (_created)
{
    <MudPaper Class="pa-5" Elevation="2" Style="border-left: 4px solid var(--mud-palette-success);">
        <MudText Typo="Typo.h5" Color="Color.Success" Style="font-weight: 700;" Class="mb-3">
            @(_run!.ArRetroaktiv ? "Retroaktiv lönekörning skapad och beräknad" : "Lönekörning skapad och beräknad")
        </MudText>
        <MudSimpleTable Dense="true" Class="mb-3">
            <tbody>
                <tr><td><strong>Period</strong></td><td>@_run!.Period</td></tr>
                @if (_run.ArRetroaktiv)
                {
                    <tr><td><strong>Avser period</strong></td><td>@_run.RetroaktivtForPeriod</td></tr>
                }
                <tr><td><strong>Antal anställda</strong></td><td>@_run.AntalAnstallda</td></tr>
                <tr><td><strong>Total brutto</strong></td><td>@_run.TotalBrutto.Amount.ToString("N0") kr</td></tr>
                <tr><td><strong>Total skatt</strong></td><td>@_run.TotalSkatt.Amount.ToString("N0") kr</td></tr>
                <tr><td><strong>Total netto</strong></td><td>@_run.TotalNetto.Amount.ToString("N0") kr</td></tr>
                <tr><td><strong>Arbetsgivaravgifter</strong></td><td>@_run.TotalArbetsgivaravgifter.Amount.ToString("N0") kr</td></tr>
                <tr><td><strong>Status</strong></td><td><MudChip T="string" Size="Size.Small" Color="Color.Info">Beräknad</MudChip></td></tr>
            </tbody>
        </MudSimpleTable>
        @if (_felAntal > 0)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-3">
                @_felAntal anställda kunde inte beräknas och hoppades över. Kontrollera deras skatte- och anställningsuppgifter.
            </MudAlert>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/lon/korning/{_run!.Id.Value}")">Granska körning</MudButton>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-5" Elevation="2">
        <MudRadioGroup T="bool" @bind-Value="_retroaktiv" Class="mb-4">
            <MudRadio T="bool" Value="@false" Color="Color.Primary">Ordinarie körning</MudRadio>
            <MudRadio T="bool" Value="@true" Color="Color.Primary">Retroaktiv körning</MudRadio>
        </MudRadioGroup>

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="4"><MudNumericField T="int" @bind-Value="_year" Label="Utbetalningsår" Variant="Variant.Outlined" Min="2020" Max="2100" /></MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="int" @bind-Value="_month" Label="Utbetalningsmånad" Variant="Variant.Outlined">
                    @for (var m = 1; m <= 12; m++) { var month = m; <MudSelectItem Value="@month">@MonthName(month)</MudSelectItem> }
                </MudSelect>
            </MudItem>
        </MudGrid>

        @if (_retroaktiv)
        {
            <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Vilken period ska räknas om?</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="4"><MudNumericField T="int" @bind-Value="_retroYear" Label="Omräkningsår" Variant="Variant.Outlined" Min="2020" Max="2100" /></MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int" @bind-Value="_retroMonth" Label="Omräkningsmånad" Variant="Variant.Outlined">
                        @for (var m = 1; m <= 12; m++) { var month = m; <MudSelectItem Value="@month">@MonthName(month)</MudSelectItem> }
                    </MudSelect>
                </MudItem>
            </MudGrid>
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-3">
                Differensen mellan den tidigare beräkningen och aktuella uppgifter betalas ut (eller återkrävs) i @MonthName(_month) @_year.
            </MudAlert>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   Style="min-height: 48px;" Class="mt-4" OnClick="SkapaKorning" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Skapa och beräkna
        </MudButton>
    </MudPaper>
}

@code {
    private int _year = 2026, _month = DateTime.Today.Month;
    private bool _retroaktiv;
    private int _retroYear = 2026, _retroMonth = Math.Max(1, DateTime.Today.Month - 1);
    private PayrollRun? _run;
    private int _felAntal;
    private bool _saving, _created;
    private string? _error;

    private async Task SkapaKorning()
    {
        _saving = true; _error = null;
        try
        {
            PayrollRunResult result;
            if (_retroaktiv)
            {
                if (_retroYear == _year && _retroMonth == _month)
                {
                    _error = "Omräkningsperioden måste skilja sig från utbetalningsperioden.";
                    return;
                }
                var retroPeriod = $"{_retroYear}-{_retroMonth:D2}";
                result = await Batch.ExecuteRetroactiveRunAsync(_year, _month, retroPeriod, "System");
            }
            else
            {
                result = await Batch.ExecutePayrollRunAsync(_year, _month, "System");
            }

            _run = result.Run;
            _felAntal = result.Fel.Count;
            _created = true;
        }
        catch (Exception ex) { _error = $"Kunde inte skapa körning: {ex.Message}"; }
        finally { _saving = false; }
    }

    private static string MonthName(int month) =>
        System.Globalization.CultureInfo.GetCultureInfo("sv-SE").DateTimeFormat.GetMonthName(month);
}
