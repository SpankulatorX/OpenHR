@page "/lon/korning/{Id:guid}"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Components.Shared
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Payroll.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Lönekörning</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/lon/korningar" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (!_found)
{
    <MudAlert Severity="Severity.Warning">Lönekörning hittades inte.</MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">
        Lönekörning @_rubrik@(_retroaktiv ? $" (retroaktiv, avser {_retroPeriod})" : "")
    </MudText>

    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.caption">Total brutto</MudText>
                <MudText Typo="Typo.h5" Style="font-weight: 700;">@_brutto</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.caption">Total skatt</MudText>
                <MudText Typo="Typo.h5" Style="font-weight: 700; color: var(--mud-palette-error);">@_skatt</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.caption">Total netto</MudText>
                <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 700;">@_netto</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.caption">Arbetsgivaravgifter</MudText>
                <MudText Typo="Typo.h5" Style="font-weight: 700;">@_ag</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (_anomalier.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-3">@_anomalier.Count löner behöver din kontroll</MudText>
        @foreach (var a in _anomalier)
        {
            <OhrSuggestionCard Title="@($"{a.Namn} — {a.Belopp}")"
                               Explanation="@a.Forklaring"
                               Level="OhrSuggestionCard.SuggestionLevel.Warning"
                               Actions="@(new Dictionary<string, string> { ["ok"] = "OK, stämmer", ["andra"] = "Ändra" })" />
        }
    }

    <MudText Typo="Typo.h6" Class="mt-6 mb-3">Löneunderlag per anställd (@_loner.Count st)</MudText>
    <MudTable Items="_loner" Dense="true" Hover="true" Elevation="2" Class="mb-4">
        <HeaderContent>
            <MudTh>Anställd</MudTh>
            <MudTh Style="text-align:right">Brutto</MudTh>
            <MudTh Style="text-align:right">Skatt</MudTh>
            <MudTh Style="text-align:right">Netto</MudTh>
            <MudTh Style="text-align:right">OB</MudTh>
            <MudTh Style="text-align:right">Arb.giv.avg</MudTh>
            <MudTh Style="text-align:right">Pension</MudTh>
            <MudTh Style="text-align:right">Rader</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Anställd">@context.Namn</MudTd>
            <MudTd DataLabel="Brutto" Style="text-align:right">@Kr(context.Brutto)</MudTd>
            <MudTd DataLabel="Skatt" Style="text-align:right; color: var(--mud-palette-error)">-@Kr(context.Skatt)</MudTd>
            <MudTd DataLabel="Netto" Style="text-align:right; font-weight:600">@Kr(context.Netto)</MudTd>
            <MudTd DataLabel="OB" Style="text-align:right">@Kr(context.OB)</MudTd>
            <MudTd DataLabel="Arb.giv.avg" Style="text-align:right">@Kr(context.AG)</MudTd>
            <MudTd DataLabel="Pension" Style="text-align:right">@Kr(context.Pension)</MudTd>
            <MudTd Style="text-align:right">
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                           OnClick="@(() => ToggleRad(context.Index))">
                    @(_expanded.Contains(context.Index) ? "Dölj" : $"{context.Lonearter.Count} rader")
                </MudButton>
            </MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (_expanded.Contains(context.Index))
            {
                <MudTr>
                    <MudTd colspan="8" Style="padding:0">
                        <MudSimpleTable Dense="true" Style="background: var(--mud-palette-background-grey)">
                            <thead>
                                <tr>
                                    <th>Löneart</th><th>Benämning</th>
                                    <th style="text-align:right">Antal</th>
                                    <th style="text-align:right">Á-pris</th>
                                    <th style="text-align:right">Belopp</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rad in context.Lonearter)
                                {
                                    <tr>
                                        <td>@rad.Kod</td>
                                        <td>@rad.Benamning</td>
                                        <td style="text-align:right">@rad.Antal.ToString("0.##")</td>
                                        <td style="text-align:right">@Kr(rad.Sats)</td>
                                        <td style="text-align:right; @(rad.ArAvdrag ? "color: var(--mud-palette-error)" : "")">@Kr(rad.Belopp)</td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudTd>
                </MudTr>
            }
        </ChildRowContent>
    </MudTable>

    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" FullWidth="true"
               Style="min-height: 64px; font-size: 1.25rem;" Class="mt-4">
        Godkänn och skicka till utbetalning
    </MudButton>

    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-3">
        Nästa steg: AGI-filen till Skatteverket skapas automatiskt den 12:e.
    </MudAlert>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private string _rubrik = "";
    private string _brutto = "";
    private string _skatt = "";
    private string _netto = "";
    private string _ag = "";
    private bool _retroaktiv;
    private string? _retroPeriod;
    private List<Anomali> _anomalier = [];
    private List<LonRad> _loner = [];
    private readonly HashSet<int> _expanded = [];
    private bool _loading = true, _found;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var run = await db.PayrollRuns
                .Include(r => r.Resultat).ThenInclude(res => res.Rader)
                .FirstOrDefaultAsync(r => r.Id == PayrollRunId.From(Id));

            if (run is null)
            {
                _found = false;
                _loading = false;
                return;
            }

            _found = true;
            _rubrik = FormatPeriod(run.Year, run.Month);
            _retroaktiv = run.ArRetroaktiv;
            _retroPeriod = run.RetroaktivtForPeriod;
            _brutto = FormatMoney(run.TotalBrutto);
            _skatt = $"-{FormatMoney(run.TotalSkatt)}";
            _netto = FormatMoney(run.TotalNetto);
            _ag = FormatMoney(run.TotalArbetsgivaravgifter);

            var anstallIds = run.Resultat.Select(r => r.AnstallId).Distinct().ToList();
            var employees = await db.Employees
                .Where(e => anstallIds.Contains(e.Id))
                .ToListAsync();
            var empNames = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _loner = run.Resultat
                .OrderBy(r => empNames.GetValueOrDefault(r.AnstallId.Value, "Okänd"))
                .Select((r, index) => new LonRad(
                    index,
                    empNames.GetValueOrDefault(r.AnstallId.Value, "Okänd"),
                    r.Brutto.Amount, r.Skatt.Amount, r.Netto.Amount,
                    r.OBTillagg.Amount, r.Arbetsgivaravgifter.Amount, r.Pensionsavgift.Amount,
                    r.Rader
                        .OrderBy(l => l.LoneartKod)
                        .Select(l => new LoneartRad(l.LoneartKod, l.Benamning, l.Antal, l.Sats.Amount, l.Belopp.Amount, l.ArAvdrag))
                        .ToList()))
                .ToList();

            BuildAnomalies(run, empNames);
        }
        catch (Exception ex) { _error = $"Kunde inte hämta lönekörning: {ex.Message}"; }
        finally { _loading = false; }
    }

    private void ToggleRad(int index)
    {
        if (!_expanded.Add(index))
            _expanded.Remove(index);
    }

    private void BuildAnomalies(PayrollRun run, Dictionary<Guid, string> empNames)
    {
        if (run.Resultat.Count == 0) return;

        var avgBrutto = run.TotalBrutto.Amount / Math.Max(run.AntalAnstallda, 1);
        var threshold = avgBrutto * 0.10m;

        var anomalousResults = run.Resultat
            .Where(r => Math.Abs(r.Brutto.Amount - avgBrutto) > threshold)
            .Take(10)
            .ToList();

        foreach (var r in anomalousResults)
        {
            var namn = empNames.GetValueOrDefault(r.AnstallId.Value, "Okänd");
            var diff = r.Brutto.Amount - avgBrutto;
            var pct = avgBrutto > 0 ? Math.Abs(diff / avgBrutto * 100) : 0;
            var direction = diff > 0 ? "+" : "";

            _anomalier.Add(new Anomali(
                namn,
                $"{r.Brutto.Amount:N0} kr (snitt {avgBrutto:N0} kr, {direction}{pct:F0}%)",
                SummarizeDeviations(r)));
        }
    }

    private static string Kr(decimal amount) => $"{amount:N0} kr";
    private static string FormatMoney(Money m) => $"{m.Amount:N0} kr";

    private static string FormatPeriod(int year, int month)
    {
        var monthNames = new[] { "", "Januari", "Februari", "Mars", "April", "Maj", "Juni",
            "Juli", "Augusti", "September", "Oktober", "November", "December" };
        return $"{monthNames[month]} {year}";
    }

    private static string SummarizeDeviations(PayrollResult r)
    {
        var parts = new List<string>();
        if (r.OBTillagg.Amount > 0) parts.Add($"OB-tillägg {r.OBTillagg.Amount:N0} kr");
        if (r.Overtidstillagg.Amount > 0) parts.Add($"Övertid {r.Overtidstillagg.Amount:N0} kr");
        if (r.Sjuklon.Amount > 0) parts.Add($"Sjuklön {r.Sjuklon.Amount:N0} kr");
        if (r.Karensavdrag.Amount > 0) parts.Add($"Karensavdrag -{r.Karensavdrag.Amount:N0} kr");
        if (r.JourTillagg.Amount > 0) parts.Add($"Jour {r.JourTillagg.Amount:N0} kr");
        if (r.ForaldraloneUtfyllnad.Amount > 0) parts.Add($"Föräldralön {r.ForaldraloneUtfyllnad.Amount:N0} kr");
        return parts.Count > 0 ? string.Join(", ", parts) : "Avvikande bruttolön";
    }

    private record Anomali(string Namn, string Belopp, string Forklaring);

    private record LonRad(
        int Index, string Namn, decimal Brutto, decimal Skatt, decimal Netto,
        decimal OB, decimal AG, decimal Pension, IReadOnlyList<LoneartRad> Lonearter);

    private record LoneartRad(string Kod, string Benamning, decimal Antal, decimal Sats, decimal Belopp, bool ArAvdrag);
}
