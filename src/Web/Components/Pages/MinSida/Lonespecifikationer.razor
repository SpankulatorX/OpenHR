@page "/minsida/lonespecifikationer"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Infrastructure.Export
@using RegionHR.Payroll.Domain
@using RegionHR.Core.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject RegionHR.Web.Services.AuthService Auth
@inject IJSRuntime JS

<PageTitle>OpenHR - Lönespecifikationer</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="/minsida/lon" Style="margin-bottom: 1rem;">Tillbaka</MudButton>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Lönespecifikationer</MudText>

@if (!Auth.EmployeeId.HasValue)
{
    <MudAlert Severity="Severity.Warning">Lönespecifikationer kräver kopplad anställd.</MudAlert>
}
else if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else if (_results.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga lönespecifikationer.</MudAlert> }
else
{
    @foreach (var r in _results)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="2">
            <div class="d-flex justify-space-between align-center mb-3" style="flex-wrap: wrap; gap: 0.5rem;">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">@r.Year-@r.Month.ToString("D2")</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                           Disabled="@_genererar"
                           OnClick="@(() => LaddaNerPdf(r))">
                    Ladda ner PDF
                </MudButton>
            </div>
            <MudGrid Spacing="3" Class="mb-3">
                <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Brutto</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@r.Brutto.Amount.ToString("N0") kr</MudText></MudItem>
                <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Skatt</MudText><MudText Typo="Typo.h5" Style="font-weight: 700; color: var(--mud-palette-error);">-@r.Skatt.Amount.ToString("N0") kr</MudText></MudItem>
                <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Netto</MudText><MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 700;">@r.Netto.Amount.ToString("N0") kr</MudText></MudItem>
                <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">AG-avgifter</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@r.Arbetsgivaravgifter.Amount.ToString("N0") kr</MudText></MudItem>
            </MudGrid>
            @if (r.OBTillagg.Amount > 0 || r.Overtidstillagg.Amount > 0 || r.Sjuklon.Amount > 0)
            {
                <MudSimpleTable Dense="true" Elevation="0">
                    <tbody>
                        @if (r.OBTillagg.Amount > 0) { <tr><td>OB-tillägg</td><td>@r.OBTillagg.Amount.ToString("N0") kr</td></tr> }
                        @if (r.Overtidstillagg.Amount > 0) { <tr><td>Övertidstillägg</td><td>@r.Overtidstillagg.Amount.ToString("N0") kr</td></tr> }
                        @if (r.Sjuklon.Amount > 0) { <tr><td>Sjuklön</td><td>@r.Sjuklon.Amount.ToString("N0") kr</td></tr> }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>
    }
}

@code {
    private List<PayrollResult> _results = [];
    private bool _loading = true;
    private bool _genererar;
    private string? _error;

    private string _namn = "Anställd";
    private string _personnummer = "";
    private string _befattning = "";

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.EmployeeId.HasValue) { _loading = false; return; }
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var empId = EmployeeId.From(Auth.EmployeeId.Value);
            _results = await db.PayrollResults
                .Include(r => r.Rader)
                .Where(r => r.AnstallId == empId)
                .OrderByDescending(r => r.Year).ThenByDescending(r => r.Month)
                .Take(12).ToListAsync();

            var emp = await db.Employees
                .Include(e => e.Anstallningar)
                .FirstOrDefaultAsync(e => e.Id == empId);
            if (emp is not null)
            {
                _namn = emp.FulltNamn;
                _personnummer = (string)emp.Personnummer;
                _befattning = emp.AktivAnstallning(DateOnly.FromDateTime(DateTime.Today))?.Befattningstitel ?? "";
            }
        }
        catch (Exception ex) { _error = $"Kunde inte hämta specifikationer: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task LaddaNerPdf(PayrollResult r)
    {
        _genererar = true;
        _error = null;
        try
        {
            var dokument = LonespecifikationDokument.FromPayrollResult(r, _namn, _personnummer, _befattning);
            var pdf = new LonespecifikationPdfGenerator().Generate(dokument);
            var base64 = Convert.ToBase64String(pdf);
            await JS.InvokeVoidAsync("downloadFile",
                $"lonespecifikation-{r.Year}-{r.Month:D2}.pdf", base64, "application/pdf");
        }
        catch (Exception ex) { _error = $"Kunde inte skapa PDF: {ex.Message}"; }
        finally { _genererar = false; }
    }
}
