@page "/minsida/lon"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Services
@using RegionHR.SharedKernel.Domain
@using RegionHR.Infrastructure.Export
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Payroll.Domain
@using RegionHR.Core.Domain
@using Microsoft.EntityFrameworkCore
@inject SelfServiceApiClient SelfService
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject AuthService Auth
@inject IJSRuntime JS

<PageTitle>OpenHR - Min lön</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/minsida" Style="margin-bottom: 1rem;">
    Tillbaka
</MudButton>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">💰 Min lön</MudText>

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _error = null)">@_error</MudAlert>
}

@if (string.IsNullOrEmpty(_senastePeriod))
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">Ingen lönedata registrerad ännu.</MudAlert>
}
else
{
    <MudPaper Class="pa-6 mb-6" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">@_senastePeriod</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.caption">Bruttolön</MudText>
                <MudText Typo="Typo.h5" Style="font-weight: 700;">@FormatKr(_senasteBrutto)</MudText>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.caption">Skatt</MudText>
                <MudText Typo="Typo.h5" Style="font-weight: 700; color: var(--mud-palette-error);">-@FormatKr(_senasteSkatt)</MudText>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.caption">Tillägg</MudText>
                <MudText Typo="Typo.h5" Style="font-weight: 700; color: var(--mud-palette-success);">+@FormatKr(_senasteTillagg)</MudText>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudText Typo="Typo.caption">Nettolön</MudText>
                <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 700;">@FormatKr(_senasteNetto)</MudText>
            </MudItem>
        </MudGrid>

        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-4"
                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                   Size="Size.Large" Style="min-height: 48px;"
                   Disabled="@_genererar"
                   OnClick="@(() => LaddaNerPdf(_senastePeriod))">
            Ladda ner lönespecifikation (PDF)
        </MudButton>
    </MudPaper>

    <MudText Typo="Typo.h6" Class="mb-3">Tidigare månader</MudText>
    @if (_historik.Count == 0)
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Ingen tidigare historik.</MudText>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="1">
            <thead>
                <tr><th>Period</th><th>Brutto</th><th>Netto</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var period in _historik)
                {
                    <tr>
                        <td>@period.Period</td>
                        <td>@period.Brutto</td>
                        <td><strong>@period.Netto</strong></td>
                        <td>
                            <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf"
                                           Size="Size.Small" Color="Color.Primary"
                                           aria-label="Ladda ner PDF"
                                           Disabled="@_genererar"
                                           OnClick="@(() => LaddaNerPdf(period.Period))" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<LonPeriod> _historik = [];
    private string _senastePeriod = "";
    private decimal _senasteBrutto, _senasteSkatt, _senasteTillagg, _senasteNetto;
    private bool _genererar;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.EmployeeId == null) { _error = "Ingen anställd kopplad till ditt konto."; return; }
        try
        {
            var data = await SelfService.GetSalaryHistoryAsync(
                EmployeeId.From(Auth.EmployeeId.Value));

            if (data.Count > 0)
            {
                var senaste = data[0];
                _senastePeriod = senaste.Period;
                _senasteBrutto = senaste.Brutto;
                _senasteSkatt = senaste.Skatt;
                _senasteTillagg = senaste.OBTillagg + senaste.Overtid;
                _senasteNetto = senaste.Netto;

                _historik = data.Skip(1).Select(r => new LonPeriod(
                    r.Period, FormatKr(r.Brutto), FormatKr(r.Netto))).ToList();
            }
        }
        catch (Exception ex) { _error = $"Kunde inte hämta lönedata: {ex.Message}"; }
    }

    private async Task LaddaNerPdf(string period)
    {
        if (Auth.EmployeeId is null || !TryParsePeriod(period, out var year, out var month)) return;
        _genererar = true;
        _error = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var empId = EmployeeId.From(Auth.EmployeeId.Value);

            var result = await db.PayrollResults
                .Include(r => r.Rader)
                .FirstOrDefaultAsync(r => r.AnstallId == empId && r.Year == year && r.Month == month);

            if (result is null)
            {
                _error = $"Ingen lönespecifikation hittades för {period}.";
                return;
            }

            var emp = await db.Employees
                .Include(e => e.Anstallningar)
                .FirstOrDefaultAsync(e => e.Id == empId);

            var namn = emp?.FulltNamn ?? "Anställd";
            var pnr = emp is not null ? (string)emp.Personnummer : "";
            var befattning = emp?.AktivAnstallning(DateOnly.FromDateTime(DateTime.Today))?.Befattningstitel ?? "";

            var dokument = LonespecifikationDokument.FromPayrollResult(result, namn, pnr, befattning);
            var pdf = new LonespecifikationPdfGenerator().Generate(dokument);
            var base64 = Convert.ToBase64String(pdf);
            await JS.InvokeVoidAsync("downloadFile",
                $"lonespecifikation-{year}-{month:D2}.pdf", base64, "application/pdf");
        }
        catch (Exception ex) { _error = $"Kunde inte skapa PDF: {ex.Message}"; }
        finally { _genererar = false; }
    }

    private static bool TryParsePeriod(string period, out int year, out int month)
    {
        year = 0; month = 0;
        var parts = period.Split('-');
        return parts.Length == 2
               && int.TryParse(parts[0], out year)
               && int.TryParse(parts[1], out month);
    }

    private static string FormatKr(decimal belopp) =>
        $"{belopp:N0} kr".Replace(",", " ");

    private record LonPeriod(string Period, string Brutto, string Netto);
}
