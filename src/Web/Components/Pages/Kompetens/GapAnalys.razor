@page "/kompetens/gapanalys"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Competence.Domain
@using RegionHR.Competence.Services
@using RegionHR.Positions.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject CompetenceGapAnalyzer Analyzer

<PageTitle>OpenHR — Gap-analys</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Kompetens gap-analys</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Jämför anställdas registrerade skills mot positionens kravprofil (PositionSkillRequirement)
    via den delade gap-motorn. Anställda utan kopplad position visas inte.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_rader.Count == 0)
{
    <MudAlert Severity="Severity.Info">Inga positioner med kravprofil och kopplad anställd hittades.</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-error);">
                <MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 700;">@_rader.Count(r => r.Analys.HarGap)</MudText>
                <MudText Typo="Typo.body2">Med gap</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-success);">
                <MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 700;">@_rader.Count(r => !r.Analys.HarGap)</MudText>
                <MudText Typo="Typo.body2">Uppfyller alla krav</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_rader.Count</MudText>
                <MudText Typo="Typo.body2">Analyserade</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_totalGapCount</MudText>
                <MudText Typo="Typo.body2">Totala gap</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudSimpleTable Hover="true" Elevation="2">
        <thead>
            <tr><th>Anställd</th><th>Position</th><th>Krav</th><th>Uppfyllda</th><th>Gap</th><th>Täckningsgrad</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var r in _rader)
            {
                <tr style="cursor: pointer;" @onclick="@(() => _expanded = _expanded == r ? null : r)">
                    <td><strong>@r.AnstallNamn</strong></td>
                    <td>@r.Analys.PositionTitel</td>
                    <td>@r.Analys.AntalKrav</td>
                    <td>@r.Analys.AntalUppfyllda</td>
                    <td>
                        @if (r.Analys.HarGap)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">@r.Analys.AntalGap gap</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">0</MudChip>
                        }
                    </td>
                    <td>
                        <MudProgressLinear Value="@r.Analys.TackningsgradProcent" Color="@(r.Analys.TackningsgradProcent >= 100 ? Color.Success : r.Analys.TackningsgradProcent >= 70 ? Color.Warning : Color.Error)"
                                           Style="min-width: 100px;" />
                        <MudText Typo="Typo.caption">@r.Analys.TackningsgradProcent%</MudText>
                    </td>
                    <td><MudIconButton Icon="@(_expanded == r ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" /></td>
                </tr>
                @if (_expanded == r)
                {
                    <tr>
                        <td colspan="7" style="padding: 0;">
                            <MudPaper Class="pa-4" Elevation="0" Style="border-top: 2px solid var(--mud-palette-primary); background: var(--mud-palette-background);">
                                <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 600;">Kompetensgap: @r.AnstallNamn</MudText>
                                @foreach (var s in r.Analys.Skills)
                                {
                                    <div class="mb-3">
                                        <div class="d-flex justify-space-between align-center mb-1">
                                            <MudText Typo="Typo.body2" Style="font-weight:600;">@s.SkillNamn</MudText>
                                            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                                nivå @s.NuvarandeNiva / krav @s.KravdNiva
                                                @if (s.ArUppfylld)
                                                {
                                                    <span>• uppfyllt</span>
                                                }
                                                else if (s.Saknas)
                                                {
                                                    <span>• saknas</span>
                                                }
                                                else
                                                {
                                                    <span>• gap @s.GapPoang</span>
                                                }
                                            </MudText>
                                        </div>
                                        <div style="display:flex; gap:4px;">
                                            @for (int n = 1; n <= 5; n++)
                                            {
                                                var fyll = n <= s.NuvarandeNiva;
                                                var krav = n <= s.KravdNiva;
                                                var farg = fyll
                                                    ? (s.ArUppfylld ? "var(--mud-palette-success)" : "var(--mud-palette-warning)")
                                                    : "var(--mud-palette-lines-default)";
                                                var kant = krav && !fyll ? "2px dashed var(--mud-palette-error)" : "1px solid transparent";
                                                <div style="flex:1; height:18px; border-radius:4px; background:@farg; border:@kant;"></div>
                                            }
                                        </div>
                                    </div>
                                }
                            </MudPaper>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<Rad> _rader = [];
    private Rad? _expanded;
    private int _totalGapCount;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var skills = await db.Skills.ToListAsync();
            var skillNamn = skills.ToDictionary(s => s.Id, s => s.Namn);
            var empSkills = await db.EmployeeSkills.ToListAsync();
            var requirements = await db.PositionSkillRequirements.ToListAsync();
            var positions = await db.Positions_Table
                .Where(p => p.InnehavareAnstallId != null && p.Status == PositionStatus.Aktiv)
                .ToListAsync();
            var employees = await db.Employees.ToListAsync();

            foreach (var pos in positions)
            {
                var emp = employees.FirstOrDefault(e => e.Id.Value == pos.InnehavareAnstallId);
                if (emp is null) continue;

                var posKrav = requirements.Where(r => r.PositionId == pos.Id).ToList();
                if (posKrav.Count == 0) continue;

                var analys = Analyzer.Analysera(
                    emp.Id.Value, pos.Id, pos.Titel, posKrav, empSkills, skillNamn);

                _rader.Add(new Rad($"{emp.Fornamn} {emp.Efternamn}", analys));
            }

            _rader = _rader.OrderByDescending(r => r.Analys.AntalGap).ToList();
            _totalGapCount = _rader.Sum(r => r.Analys.AntalGap);
        }
        catch (Exception ex) { _error = $"Kunde inte utföra gap-analys: {ex.Message}"; }
        finally { _loading = false; }
    }

    private sealed record Rad(string AnstallNamn, RegionHR.Competence.Services.GapAnalys Analys);
}
