@page "/rapporter/prediktion"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Infrastructure.Analytics
@using RegionHR.Analytics.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject FlightRiskService RiskService

<PageTitle>OpenHR - Prediktiv analys</PageTitle>
<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Prediktiv analys</MudText>
<MudText Typo="Typo.body2" Color="Color.Default" Class="mb-4">Modeller för att bedöma personalflöden, sjukfrånvaro och kostnader.</MudText>

<MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-6">
    <strong>Ärlig statusbild.</strong> Endast <em>uppsägningsriskmodellen</em> är aktiverad. Den drivs av en
    <strong>regelbaserad heuristik</strong> (FlightRiskService) som beräknas live ur anställningsdata — inte en tränad
    AI-/ML-modell, och därför visas inga precisions-/accuracy-siffror. Övriga modeller (bemannings-, sjukfrånvaro- och
    lönekostnadsprognos) är <strong>ej aktiverade</strong>: de kräver ML-infrastruktur som inte ingår i OpenHR och visas
    här som planerade.
</MudAlert>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-6">
        @foreach (var model in _models)
        {
            var aktiv = ArAktiverad(model.Typ);
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4" Elevation="2" Style="@($"border-top: 4px solid {(aktiv ? "var(--mud-palette-success)" : "var(--mud-palette-lines-default)")};")">
                    <MudIcon Icon="@GetModelIcon(model.Typ)" Color="@(aktiv ? Color.Success : Color.Default)" Size="Size.Large" />
                    <MudText Typo="Typo.h6" Class="mt-2" Style="font-weight: 600;">@model.Namn</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-1">@GetModelBeskrivning(model.Typ)</MudText>
                    <MudDivider Class="my-3" />
                    <MudChip T="string" Size="Size.Small" Color="@(aktiv ? Color.Success : Color.Default)">
                        @(aktiv ? "Aktiverad (regelbaserad)" : "Ej aktiverad")
                    </MudChip>
                    @if (aktiv)
                    {
                        <div class="d-flex justify-space-between mt-3">
                            <MudText Typo="Typo.body2"><strong>Analyserade:</strong></MudText>
                            <MudText Typo="Typo.body2">@_risk.Count</MudText>
                        </div>
                        <div class="d-flex justify-space-between mt-1">
                            <MudText Typo="Typo.body2"><strong>Hög risk:</strong></MudText>
                            <MudText Typo="Typo.body2" Color="Color.Error">@_risk.Count(r => r.Niva == FlightRiskNiva.Hog)</MudText>
                        </div>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Class="mt-3" Style="display:block;color:var(--mud-palette-text-secondary);">
                            Demonstration — genererar inga resultat.
                        </MudText>
                    }
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <div class="d-flex justify-space-between align-center mb-3">
        <MudText Typo="Typo.h6">Uppsägningsrisk per anställd (regelbaserad)</MudText>
        <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward"
                   Href="/rapporter/flight-risk">Öppna full analys</MudButton>
    </div>
    @if (_risk.Count == 0)
    {
        <MudPaper Class="pa-6 text-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Default" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-3" Color="Color.Default">Inga anställda med aktiv anställning</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default">Riskpoäng beräknas live när det finns anställningsdata i databasen.</MudText>
        </MudPaper>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead>
                <tr>
                    <th>Modell</th>
                    <th>Anställd</th>
                    <th>Befattning</th>
                    <th>Poäng</th>
                    <th>Risknivå</th>
                    <th>Beräknad</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _risk.Take(20))
                {
                    <tr>
                        <td>Uppsägningsriskmodell</td>
                        <td><strong>@r.Namn</strong></td>
                        <td>@r.Befattning</td>
                        <td>@r.Poang / @r.MaxPoang</td>
                        <td>
                            <MudChip T="string" Size="Size.Small" Color="@GetRiskColor(r.Niva)">@GetRiskText(r.Niva)</MudChip>
                        </td>
                        <td>@_beraknadVid.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
        @if (_risk.Count > 20)
        {
            <MudText Typo="Typo.caption" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
                Visar de 20 med högst poäng av @_risk.Count analyserade. Se full analys för samtliga.
            </MudText>
        }
    }
}

@code {
    private List<PredictionModel> _models = [];
    private List<FlightRiskResult> _risk = [];
    private DateTime _beraknadVid = DateTime.Now;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _models = await db.PredictionModels.OrderBy(m => m.Typ).ToListAsync();

            var employees = await db.Employees.Include(e => e.Anstallningar).ToListAsync();
            _risk = RiskService.BeraknaForAlla(employees);
            _beraknadVid = DateTime.Now;
        }
        catch (Exception ex) { _error = $"Kunde inte ladda prediktioner: {ex.Message}"; }
        finally { _loading = false; }
    }

    // Endast uppsägningsriskmodellen (Attrition) backas av en verklig, regelbaserad beräkning.
    private static bool ArAktiverad(string typ) => typ == "Attrition";

    private string GetModelIcon(string typ) => typ switch
    {
        "Attrition" => Icons.Material.Filled.PersonOff,
        "HeadcountForecast" => Icons.Material.Filled.Groups,
        "SickLeaveForecast" => Icons.Material.Filled.LocalHospital,
        "LaborCostForecast" => Icons.Material.Filled.AccountBalance,
        _ => Icons.Material.Filled.Psychology
    };

    private string GetModelBeskrivning(string typ) => typ switch
    {
        "Attrition" => "Regelbaserad heuristik som flaggar medarbetare med förhöjd uppsägningsrisk ur anställningsdata.",
        "HeadcountForecast" => "Prognos för framtida bemanningsbehov baserat på turnover, pension och tillväxt.",
        "SickLeaveForecast" => "Förutser sjukfrånvaro per enhet baserat på säsong, historik och arbetsbelastning.",
        "LaborCostForecast" => "Beräknar framtida lönekostnader inklusive OB, övertid och arbetsgivaravgifter.",
        _ => ""
    };

    private static Color GetRiskColor(FlightRiskNiva niva) => niva switch
    {
        FlightRiskNiva.Hog => Color.Error,
        FlightRiskNiva.Medel => Color.Warning,
        FlightRiskNiva.Lag => Color.Success,
        _ => Color.Default
    };

    private static string GetRiskText(FlightRiskNiva niva) => niva switch
    {
        FlightRiskNiva.Hog => "Hög",
        FlightRiskNiva.Medel => "Medel",
        FlightRiskNiva.Lag => "Låg",
        _ => "—"
    };
}
