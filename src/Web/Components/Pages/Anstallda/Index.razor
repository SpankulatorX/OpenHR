@page "/anstallda"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Export
@using RegionHR.Web.Services
@using Microsoft.Extensions.Localization
@inject RegionHR.Web.Services.AnstallningService Service
@inject RegionHR.Web.Services.UnitScopeService Scope
@inject NavigationManager Nav
@inject ExportService Export
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> L

<PageTitle>OpenHR - @L["Employees"]</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">@L["Employees"]</MudText>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="ExporteraCsv"
                   Disabled="_exporterar" Style="min-height: 48px;">
            CSV
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Download" OnClick="ExporteraExcel"
                   Disabled="_exporterar" Style="min-height: 48px;">
            @L["ExportExcel"]
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Add" Href="/anstallda/ny" Style="min-height: 48px;">
            @L["NewEmployee"]
        </MudButton>
    </div>
</div>

<MudTable @ref="_table" T="EmployeeListItem" ServerData="LaddaData" Hover="true" Elevation="2"
          Dense="false" OnRowClick="OppnaRad" RowStyle="cursor: pointer;" Class="mb-2">
    <ToolBarContent>
        <MudTextField T="string" @bind-Value="_sokterm" Label="@L["SearchName"]"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="300"
                      @bind-Value:after="ReloadTable" Style="max-width: 360px;" />
        @if (!Scope.IsUnitScoped && _enheter.Count > 0)
        {
            <MudSelect T="Guid?" @bind-Value="_valdEnhet" Label="@L["Unit"]"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                       @bind-Value:after="ReloadTable" Class="ml-3" Style="max-width: 280px;">
                @foreach (var e in _enheter)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Namn (@e.Kostnadsstalle)</MudSelectItem>
                }
            </MudSelect>
        }
        <MudSpacer />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>@L["Name"]</MudTh>
        <MudTh>@L["PersonalNumber"]</MudTh>
        <MudTh>@L["JobTitle"]</MudTh>
        <MudTh>@L["Unit"]</MudTh>
        <MudTh>@L["EmploymentForm"]</MudTh>
        <MudTh>@L["EmploymentRate"]</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@L["Name"]"><strong>@context.Fornamn @context.Efternamn</strong></MudTd>
        <MudTd DataLabel="@L["PersonalNumber"]">@context.PersonnummerMaskerat</MudTd>
        <MudTd DataLabel="@L["JobTitle"]">@context.Befattning</MudTd>
        <MudTd DataLabel="@L["Unit"]">@context.Enhet</MudTd>
        <MudTd DataLabel="@L["EmploymentForm"]">@context.Anstallningsform</MudTd>
        <MudTd DataLabel="@L["EmploymentRate"]">@context.Sysselsattningsgrad%</MudTd>
        <MudTd>
            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                       OnClick="@(() => Nav.NavigateTo($"/anstallda/{context.Id.Value}"))">@L["Open"]</MudButton>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudAlert Severity="Severity.Info" Class="my-2">@L["NoEmployeesFound"]</MudAlert>
    </NoRecordsContent>
    <LoadingContent>
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    </LoadingContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }" />
    </PagerContent>
</MudTable>

@if (_visarCsv)
{
    <MudPaper Class="pa-4 mt-4" Elevation="2" Style="border-left: 4px solid var(--mud-palette-primary);">
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.h6" Style="font-weight: 600;">@L["CSVExport"] — @L["Employees"]</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _visarCsv = false)" />
        </div>
        <MudTextField T="string" Value="@_csvInnehall" Variant="Variant.Outlined" Lines="10"
                      Style="font-family: 'Courier New', monospace; font-size: 0.8rem;" ReadOnly="true" />
        <div class="d-flex gap-2 mt-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="KopieraCsv">
                @(_kopierad ? L["Copied"] : L["CopyToClipboard"])
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Download" OnClick="LaddaNerCsv">
                @L["DownloadCSV"]
            </MudButton>
        </div>
    </MudPaper>
}

@code {
    private MudTable<EmployeeListItem> _table = null!;
    private string _sokterm = "";
    private Guid? _valdEnhet;
    private bool _exporterar;
    private List<EnhetVal> _enheter = [];

    protected override async Task OnInitializedAsync()
    {
        // Enhetsväljaren visas bara för HR/Admin (chef är låst till sin egen enhet).
        if (!Scope.IsUnitScoped)
        {
            try { _enheter = await Service.HamtaEnheterAsync(); }
            catch { _enheter = []; }
        }
    }

    private Task ReloadTable() => _table.ReloadServerData();

    /// <summary>
    /// ServerData-callback för MudTable: laddar EN sida ur DB (Skip/Take + totalantal).
    /// En chef scopas till sin enhet direkt i SQL-frågan; kan enheten inte härledas
    /// visas ingenting (fail-closed) i stället för hela organisationen.
    /// </summary>
    private async Task<TableData<EmployeeListItem>> LaddaData(TableState state, CancellationToken token)
    {
        var (visa, enhet) = await BestamEnhetsfilterAsync();
        if (!visa)
            return new TableData<EmployeeListItem> { Items = [], TotalItems = 0 };

        try
        {
            var sida = await Service.HamtaSidaAsync(
                state.Page * state.PageSize,
                state.PageSize,
                string.IsNullOrWhiteSpace(_sokterm) ? null : _sokterm,
                enhet,
                token);
            return new TableData<EmployeeListItem> { Items = sida.Items, TotalItems = sida.TotalAntal };
        }
        catch
        {
            return new TableData<EmployeeListItem> { Items = [], TotalItems = 0 };
        }
    }

    /// <summary>
    /// Löser det effektiva enhetsfiltret. Returnerar (visa, enhet):
    /// visa=false innebär fail-closed (chef utan härledbar enhet → visa inget).
    /// </summary>
    private async Task<(bool Visa, Guid? Enhet)> BestamEnhetsfilterAsync()
    {
        if (Scope.IsUnitScoped)
        {
            var unit = await Scope.GetCurrentUnitIdAsync();
            return unit is null ? (false, (Guid?)null) : (true, unit);
        }
        return (true, _valdEnhet);
    }

    private void OppnaRad(TableRowClickEventArgs<EmployeeListItem> args)
    {
        if (args.Item is { } rad)
            Nav.NavigateTo($"/anstallda/{rad.Id.Value}");
    }

    private bool _visarCsv;
    private string _csvInnehall = "";
    private bool _kopierad;

    private async Task<List<EmployeeListItem>> HamtaExportdataAsync()
    {
        var (visa, enhet) = await BestamEnhetsfilterAsync();
        if (!visa) return [];
        return await Service.HamtaForExportAsync(
            string.IsNullOrWhiteSpace(_sokterm) ? null : _sokterm, enhet);
    }

    private async Task ExporteraCsv()
    {
        _exporterar = true;
        try
        {
            var rader = await HamtaExportdataAsync();
            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"{L["FirstName"]};{L["LastName"]};{L["PersonalNumber"]};{L["JobTitle"]};{L["Unit"]};{L["EmploymentForm"]};{L["EmploymentRate"]} (%)");
            foreach (var a in rader)
                sb.AppendLine($"{a.Fornamn};{a.Efternamn};{a.PersonnummerMaskerat};{a.Befattning};{a.Enhet};{a.Anstallningsform};{a.Sysselsattningsgrad}");
            _csvInnehall = sb.ToString();
            _visarCsv = true;
            _kopierad = false;
        }
        finally { _exporterar = false; }
    }

    private async Task KopieraCsv()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _csvInnehall);
        _kopierad = true;
    }

    private async Task LaddaNerCsv()
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(_csvInnehall);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", $"anstallda-{DateTime.Now:yyyy-MM-dd}.csv", base64, "text/csv");
    }

    private async Task ExporteraExcel()
    {
        _exporterar = true;
        try
        {
            var rader = await HamtaExportdataAsync();
            var headers = new[] { L["FirstName"].Value, L["LastName"].Value, L["PersonalNumber"].Value, L["JobTitle"].Value, L["Unit"].Value, L["EmploymentForm"].Value, $"{L["EmploymentRate"]} (%)" };

            var excelBytes = Export.ToExcel(
                rader,
                L["Employees"].Value,
                headers,
                a => new object[]
                {
                    a.Fornamn,
                    a.Efternamn,
                    a.PersonnummerMaskerat,
                    a.Befattning,
                    a.Enhet,
                    a.Anstallningsform,
                    a.Sysselsattningsgrad
                });

            var base64 = Convert.ToBase64String(excelBytes);
            var timestamp = DateTime.Now.ToString("yyyy-MM-dd");
            await JS.InvokeVoidAsync("downloadFile",
                $"anstallda-{timestamp}.xlsx",
                base64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
        finally { _exporterar = false; }
    }
}
