@page "/offboarding"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Offboarding.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>OpenHR - Offboarding</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Offboarding</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" Href="/offboarding/ny">Nytt ärende</MudButton>
</div>

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_cases.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga offboarding-ärenden registrerade.</MudAlert>
}
else
{
    <MudSimpleTable Hover="true" Elevation="2">
        <thead>
            <tr>
                <th>Anställd</th>
                <th>Anledning</th>
                <th>Sista dag</th>
                <th>Status</th>
                <th>Checklista</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in _cases)
            {
                var total = c.Steg.Count;
                var done = c.Steg.Count(s => s.Klar);
                var pct = total > 0 ? (int)(100.0 * done / total) : 0;
                <tr style="cursor: pointer;" @onclick="@(() => Nav.NavigateTo($"/offboarding/{c.Id}"))">
                    <td><strong>@Namn(c.AnstallId)</strong></td>
                    <td>@AnledningText(c.Anledning)</td>
                    <td>@c.SistaArbetsdag.ToString("yyyy-MM-dd")</td>
                    <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(c.Status)">@StatusText(c.Status)</MudChip></td>
                    <td><MudProgressLinear Color="@ProgressFarg(pct)" Value="@pct" Style="min-width: 100px;" /> <MudText Typo="Typo.caption">@done/@total</MudText></td>
                    <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Nav.NavigateTo($"/offboarding/{c.Id}"))">Öppna</MudButton></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<OffboardingCase> _cases = [];
    private Dictionary<Guid, string> _namn = new();
    private bool _loading = true;
    private string? _error;

    private string Namn(Guid anstallId) => _namn.GetValueOrDefault(anstallId, "Okänd anställd");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            _cases = await db.OffboardingCases
                .Include(c => c.Steg)
                .OrderByDescending(c => c.SkapadVid)
                .Take(50)
                .ToListAsync();

            var ids = _cases.Select(c => new EmployeeId(c.AnstallId)).Distinct().ToList();
            var employees = await db.Employees.Where(e => ids.Contains(e.Id)).ToListAsync();
            _namn = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");
        }
        catch (Exception ex) { _error = $"Kunde inte hämta offboarding-ärenden: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string AnledningText(AvslutAnledning a) => a switch
    {
        AvslutAnledning.EgenBegaran => "Egen uppsägning",
        AvslutAnledning.Uppsagning => "Uppsägning",
        AvslutAnledning.Pension => "Pension",
        AvslutAnledning.Vikariat_Slut => "Vikariat slut",
        AvslutAnledning.Provanstallning_Avbruten => "Provanst. avbruten",
        AvslutAnledning.Overgang => "Övergång",
        AvslutAnledning.Dodsfall => "Dödsfall",
        AvslutAnledning.Annat => "Annat",
        _ => a.ToString()
    };

    private static Color StatusFarg(OffboardingStatus s) => s switch
    {
        OffboardingStatus.Skapad => Color.Info,
        OffboardingStatus.Pagar => Color.Warning,
        OffboardingStatus.Slutford => Color.Success,
        _ => Color.Default
    };

    private static string StatusText(OffboardingStatus s) => s switch
    {
        OffboardingStatus.Skapad => "Skapad",
        OffboardingStatus.Pagar => "Pågår",
        OffboardingStatus.Slutford => "Slutförd",
        _ => s.ToString()
    };

    private static Color ProgressFarg(int pct) => pct switch
    {
        100 => Color.Success,
        >= 50 => Color.Warning,
        _ => Color.Info
    };
}
