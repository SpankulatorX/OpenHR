@page "/gdpr"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.GDPR.Domain
@using RegionHR.SharedKernel.Domain
@using RegionHR.Infrastructure.GDPR
@using RegionHR.Infrastructure.Export
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject RegisterutdragGenerator Generator
@inject PdfGenerator Pdf
@inject IJSRuntime JS

<PageTitle>OpenHR - GDPR</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">GDPR-efterlevnad</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="4"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-error);"><MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 700;">@_expiredCount</MudText><MudText Typo="Typo.body2">Försenade DSR</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-warning);"><MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">@_pendingCount</MudText><MudText Typo="Typo.body2">Väntande DSR</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-success);"><MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 700;">@_compliancePercent%</MudText><MudText Typo="Typo.body2">DSR-efterlevnad</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3">Registrerades begäran (DSR)</MudText>

    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mb-3"
               StartIcon="@Icons.Material.Filled.Description"
               OnClick="GenereraRegisterutdrag">
        Generera registerutdrag
    </MudButton>

    @if (_requests.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">Inga DSR-begäran registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
            <thead><tr><th>Typ</th><th>Anställd-ID</th><th>Inkom</th><th>Deadline</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var req in _requests)
                {
                    <tr>
                        <td>@FormatTyp(req.Typ)</td>
                        <td><strong>@req.AnstallId.ToString()[..8]...</strong></td>
                        <td>@req.Mottagen.ToLocalTime().ToString("yyyy-MM-dd")</td>
                        <td>@req.Deadline.ToLocalTime().ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (req.ArForsenad)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error">Försenad</MudChip>
                            }
                            else
                            {
                                @switch (req.Status)
                                {
                                    case RequestStatus.Mottagen:
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">Ny</MudChip>
                                        break;
                                    case RequestStatus.UnderBehandling:
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Pågår</MudChip>
                                        break;
                                    case RequestStatus.Klar:
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Klar</MudChip>
                                        break;
                                    case RequestStatus.Avslagen:
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">Avslagen</MudChip>
                                        break;
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    @* Anonymiseringskö — ingen entity stödjer detta ännu *@
    <MudText Typo="Typo.h6" Class="mt-6 mb-3">Anonymiseringskö</MudText>
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga poster i anonymiseringskö. Automatisk anonymisering kräver retentions-entity (ej implementerad).</MudAlert>
}

@if (_showRegisterutdrag)
{
    <MudDialog @bind-Visible="_showRegisterutdrag" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
        <TitleContent>
            <MudText Typo="Typo.h6">Generera registerutdrag</MudText>
        </TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_registerutdragAnstallId" Label="Anställd-ID (GUID)" Variant="Variant.Outlined" Class="mb-3" />
            <MudText Typo="Typo.caption" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
                Fullständigt registerutdrag enligt GDPR Art 15 samlar personuppgifter, anställningar, ärenden,
                löneresultat, ledighet, dokument, certifieringar, medarbetarsamtal, LAS-uppföljning, rehab och granskningslogg.
            </MudText>
            @if (_registerutdragResult is not null)
            {
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight: 700;">Förhandsvisning</MudText>
                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@_registerutdragResult</MudText>
                </MudPaper>
            }
            @if (_nedladdningsInfo is not null)
            {
                <MudAlert Severity="Severity.Success" Class="mt-3" Variant="Variant.Text">@_nedladdningsInfo</MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showRegisterutdrag = false)">Stäng</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="HamtaRegisterutdrag">Förhandsvisa</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.DataObject"
                       Disabled="@_genererar" OnClick="@(() => LaddaNer("json"))">Ladda ner JSON</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PictureAsPdf"
                       Disabled="@_genererar" OnClick="@(() => LaddaNer("pdf"))">Ladda ner PDF</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private List<DataSubjectRequest> _requests = [];
    private int _expiredCount, _pendingCount, _compliancePercent;
    private bool _loading = true;
    private string? _error;

    private bool _showRegisterutdrag;
    private bool _genererar;
    private string _registerutdragAnstallId = "";
    private string? _registerutdragResult;
    private string? _nedladdningsInfo;

    protected override async Task OnInitializedAsync()
    {
        await LaddaDsr();
        _loading = false;
    }

    private async Task LaddaDsr()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _requests = await db.DataSubjectRequests
                .OrderByDescending(r => r.Mottagen)
                .Take(50)
                .ToListAsync();

            _expiredCount = _requests.Count(r => r.ArForsenad);
            _pendingCount = _requests.Count(r => r.Status == RequestStatus.Mottagen || r.Status == RequestStatus.UnderBehandling);

            _compliancePercent = _requests.Count > 0
                ? (int)((double)_requests.Count(r => r.Status == RequestStatus.Klar) / _requests.Count * 100)
                : 0;
        }
        catch (Exception ex) { _error = $"Kunde inte hämta GDPR-data: {ex.Message}"; }
    }

    private void GenereraRegisterutdrag()
    {
        _showRegisterutdrag = true;
        _registerutdragResult = null;
        _nedladdningsInfo = null;
        _registerutdragAnstallId = "";
    }

    private async Task LaddaNer(string format)
    {
        _nedladdningsInfo = null;
        if (!Guid.TryParse(_registerutdragAnstallId, out var anstallId))
        {
            _registerutdragResult = "Ogiltigt anställd-ID. Ange ett giltigt GUID.";
            return;
        }

        _genererar = true;
        try
        {
            // Anropar den kanoniska infrastruktur-generatorn (samma väg som REST-API:t).
            var json = await Generator.GenerateAsync(anstallId);
            var kort = anstallId.ToString()[..8];

            if (format == "pdf")
            {
                var bytes = Pdf.GenerateEnkeltDokument("Registerutdrag enligt GDPR Art 15", json);
                await JS.InvokeVoidAsync("downloadFile", $"registerutdrag_{kort}.pdf",
                    Convert.ToBase64String(bytes), "application/pdf");
            }
            else
            {
                var bytes = new byte[] { 0xEF, 0xBB, 0xBF }
                    .Concat(System.Text.Encoding.UTF8.GetBytes(json)).ToArray();
                await JS.InvokeVoidAsync("downloadFile", $"registerutdrag_{kort}.json",
                    Convert.ToBase64String(bytes), "application/json");
            }

            // Logga begäran som en slutförd DSR så listan och efterlevnadsmåtten blir riktiga.
            await using var db = await DbFactory.CreateDbContextAsync();
            var dsr = DataSubjectRequest.Skapa(anstallId, RequestType.Registerutdrag);
            dsr.Slutfor($"registerutdrag_{kort}.{format}");
            db.DataSubjectRequests.Add(dsr);
            await db.SaveChangesAsync();
            await LaddaDsr();

            _nedladdningsInfo = $"Registerutdrag ({format.ToUpper()}) genererat och loggat som slutförd DSR.";
        }
        catch (Exception ex)
        {
            _registerutdragResult = $"Kunde inte generera registerutdrag: {ex.Message}";
        }
        finally { _genererar = false; }
    }

    private async Task HamtaRegisterutdrag()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (!Guid.TryParse(_registerutdragAnstallId, out var anstallId))
        {
            _registerutdragResult = "Ogiltigt anställd-ID. Ange ett giltigt GUID.";
            return;
        }

        try
        {
            var employee = await db.Employees
                .Include(e => e.Anstallningar)
                .FirstOrDefaultAsync(e => e.Id == EmployeeId.From(anstallId));

            if (employee is null)
            {
                _registerutdragResult = "Ingen anställd hittades med angivet ID.";
                return;
            }

            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"Namn: {employee.Fornamn} {employee.Efternamn}");
            sb.AppendLine($"Personnummer: {employee.Personnummer}");
            sb.AppendLine($"E-post: {employee.Epost ?? "Ej registrerad"}");
            sb.AppendLine($"Telefon: {employee.Telefon ?? "Ej registrerad"}");
            sb.AppendLine($"Kommun: {employee.Kommun ?? "Ej registrerad"}");

            if (employee.Adress is not null)
                sb.AppendLine($"Adress: {employee.Adress.Gatuadress}, {employee.Adress.Postnummer} {employee.Adress.Ort}");

            sb.AppendLine($"Antal anställningar: {employee.Anstallningar.Count}");

            _registerutdragResult = sb.ToString();
        }
        catch (Exception ex)
        {
            _registerutdragResult = $"Kunde inte hämta data: {ex.Message}";
        }
    }

    private static string FormatTyp(RequestType typ) => typ switch
    {
        RequestType.Registerutdrag => "Registerutdrag",
        RequestType.Radering => "Radering",
        RequestType.Dataportabilitet => "Dataportabilitet",
        RequestType.Rattelse => "Rättelse",
        _ => typ.ToString()
    };
}

