@page "/arbetsmiljo"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using System.Text
@using RegionHR.Infrastructure.Arbetsmiljo
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>OpenHR — Arbetsmiljö (SAM)</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Arbetsmiljö (SAM)</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Systematiskt arbetsmiljöarbete. Data hämtas från databasen.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-error);">
                <MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 700;">@_incidents.Count(i => i.Status != IncidentStatus.Avslutad)</MudText>
                <MudText Typo="Typo.body2">Öppna ärenden</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_rounds.Count(r => r.Status == SafetyRoundStatus.Planerad)</MudText>
                <MudText Typo="Typo.body2">Planerade skyddsronder</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-warning);">
                <MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">@_risks.Count(r => r.RiskVarde >= 10)</MudText>
                <MudText Typo="Typo.body2">Höga risker (≥10)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_risks.Count</MudText>
                <MudText Typo="Typo.body2">Riskbedömningar</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4">
        @* === TILLBUD / OLYCKOR / ARBETSSKADOR === *@
        <MudTabPanel Text="@($"Tillbud & skador ({_incidents.Count})")">
            <div class="pa-4">
                <div class="d-flex gap-2 mb-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="@(() => _showIncidentForm = !_showIncidentForm)">
                        @(_showIncidentForm ? "Stäng" : "Rapportera händelse")
                    </MudButton>
                    @if (_incidents.Count > 0)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Download" OnClick="LaddaNerIncidenterCsv">
                            Ladda ner CSV
                        </MudButton>
                    }
                </div>

                @if (_showIncidentForm)
                {
                    <MudPaper Class="pa-4 mb-4" Elevation="1" Style="border-left: 4px solid var(--mud-palette-primary);">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6"><MudTextField @bind-Value="_newIncRapporterare" Label="Rapportör" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect @bind-Value="_newIncEnhetId" Label="Enhet" Variant="Variant.Outlined">
                                    @foreach (var e in _enheter) { <MudSelectItem T="Guid" Value="@e.Key">@e.Value</MudSelectItem> }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect @bind-Value="_newIncTyp" Label="Typ av händelse" Variant="Variant.Outlined">
                                    @foreach (var t in Enum.GetValues<IncidentTyp>()) { <MudSelectItem Value="@t">@TypText(t)</MudSelectItem> }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6"><MudTextField @bind-Value="_newIncPlats" Label="Plats" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect @bind-Value="_newIncAllvarlighet" Label="Allvarlighetsgrad" Variant="Variant.Outlined">
                                    @foreach (var a in Enum.GetValues<IncidentAllvarlighetsgrad>()) { <MudSelectItem Value="@a">@a</MudSelectItem> }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12"><MudTextField @bind-Value="_newIncBeskrivning" Label="Beskrivning" Variant="Variant.Outlined" Lines="2" /></MudItem>
                            <MudItem xs="12"><MudTextField @bind-Value="_newIncAtgard" Label="Åtgärdsförslag" Variant="Variant.Outlined" /></MudItem>
                        </MudGrid>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SparaIncident"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newIncBeskrivning))">Spara</MudButton>
                    </MudPaper>
                }

                <MudSimpleTable Hover="true" Elevation="1">
                    <thead><tr><th>Datum</th><th>Rapportör</th><th>Enhet</th><th>Plats</th><th>Allvarlighet</th><th>Typ</th><th>Status</th><th>Åtgärd</th></tr></thead>
                    <tbody>
                        @foreach (var i in _incidents.OrderByDescending(i => i.Datum))
                        {
                            <tr>
                                <td>@i.Datum.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td>@i.RapporterareNamn</td>
                                <td>@GetEnhetNamn(i.EnhetId)</td>
                                <td>@i.Plats</td>
                                <td><MudChip T="string" Size="Size.Small" Color="@AllvarlighetFarg(i.Allvarlighetsgrad)">@i.Allvarlighetsgrad</MudChip></td>
                                <td>@TypText(i.Typ)</td>
                                <td><MudChip T="string" Size="Size.Small" Color="@IncidentStatusFarg(i.Status)">@StatusText(i.Status)</MudChip></td>
                                <td>
                                    @if (i.NastaStatus is { } nasta)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.ArrowForward"
                                                   OnClick="@(() => AvanceraIncident(i))">@StatusText(nasta)</MudButton>
                                    }
                                    else
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                                                   StartIcon="@Icons.Material.Filled.Undo"
                                                   OnClick="@(() => AteroppnaIncident(i))">Återöppna</MudButton>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </div>
        </MudTabPanel>

        @* === SKYDDSRONDER === *@
        <MudTabPanel Text="@($"Skyddsronder ({_rounds.Count})")">
            <div class="pa-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mb-3"
                           OnClick="@(() => _showRoundForm = !_showRoundForm)">
                    @(_showRoundForm ? "Stäng" : "Planera skyddsrond")
                </MudButton>

                @if (_showRoundForm)
                {
                    <MudPaper Class="pa-4 mb-4" Elevation="1" Style="border-left: 4px solid var(--mud-palette-primary);">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="4"><MudDatePicker @bind-Date="_newRoundDatum" Label="Datum" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12" sm="4">
                                <MudSelect @bind-Value="_newRoundEnhetId" Label="Enhet" Variant="Variant.Outlined">
                                    @foreach (var e in _enheter) { <MudSelectItem T="Guid" Value="@e.Key">@e.Value</MudSelectItem> }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="4"><MudTextField @bind-Value="_newRoundDeltagare" Label="Deltagare" Variant="Variant.Outlined" /></MudItem>
                        </MudGrid>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SparaRound"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newRoundDeltagare))">Spara</MudButton>
                    </MudPaper>
                }

                <MudSimpleTable Hover="true" Elevation="1">
                    <thead><tr><th>Datum</th><th>Enhet</th><th>Deltagare</th><th>Brister</th><th>Status</th><th>Åtgärd</th></tr></thead>
                    <tbody>
                        @foreach (var r in _rounds.OrderByDescending(r => r.Datum))
                        {
                            <tr>
                                <td>@r.Datum.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td>@GetEnhetNamn(r.EnhetId)</td>
                                <td>@r.Deltagare</td>
                                <td>@r.AntalBrister</td>
                                <td><MudChip T="string" Size="Size.Small" Color="@RondStatusFarg(r.Status)">@r.Status</MudChip></td>
                                <td>
                                    @if (r.Status == SafetyRoundStatus.Planerad)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.FactCheck"
                                                   OnClick="@(() => OppnaRondResultat(r))">Registrera resultat</MudButton>
                                    }
                                    else if (r.Status == SafetyRoundStatus.Genomford)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                                                   StartIcon="@Icons.Material.Filled.Done"
                                                   OnClick="@(() => AvslutaRound(r))">Avsluta</MudButton>
                                    }
                                </td>
                            </tr>
                            @if (_roundBeingEdited?.Id == r.Id)
                            {
                                <tr>
                                    <td colspan="6" style="padding: 0;">
                                        <MudPaper Class="pa-4" Elevation="0" Style="border-left: 4px solid var(--mud-palette-primary); background: var(--mud-palette-background);">
                                            <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">Registrera resultat av skyddsronden</MudText>
                                            <MudGrid Spacing="2">
                                                <MudItem xs="12" sm="3">
                                                    <MudNumericField T="int" @bind-Value="_editBrister" Label="Antal brister" Min="0" Variant="Variant.Outlined" />
                                                </MudItem>
                                                <MudItem xs="12" sm="9">
                                                    <MudTextField @bind-Value="_editAnteckningar" Label="Anteckningar (upptäckta brister m.m.)" Variant="Variant.Outlined" Lines="2" />
                                                </MudItem>
                                            </MudGrid>
                                            <div class="d-flex gap-2 mt-3">
                                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenomforRound">Spara resultat</MudButton>
                                                <MudButton Variant="Variant.Text" OnClick="@(() => _roundBeingEdited = null)">Avbryt</MudButton>
                                            </div>
                                        </MudPaper>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </MudSimpleTable>
            </div>
        </MudTabPanel>

        @* === RISKBEDÖMNINGAR === *@
        <MudTabPanel Text="@($"Riskbedömningar ({_risks.Count})")">
            <div class="pa-4">
                <div class="d-flex gap-2 mb-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="@(() => _showRiskForm = !_showRiskForm)">
                        @(_showRiskForm ? "Stäng" : "Ny riskbedömning")
                    </MudButton>
                    @if (_risks.Count > 0)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Download" OnClick="LaddaNerRiskerCsv">
                            Ladda ner CSV
                        </MudButton>
                    }
                </div>

                @if (_showRiskForm)
                {
                    <MudPaper Class="pa-4 mb-4" Elevation="1" Style="border-left: 4px solid var(--mud-palette-primary);">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6"><MudTextField @bind-Value="_newRiskNamn" Label="Risknamn" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12" sm="3">
                                <MudSelect @bind-Value="_newRiskSannolikhet" Label="Sannolikhet (1-5)" Variant="Variant.Outlined">
                                    @for (int n = 1; n <= 5; n++) { var v = n; <MudSelectItem Value="@v">@v</MudSelectItem> }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="3">
                                <MudSelect @bind-Value="_newRiskKonsekvens" Label="Konsekvens (1-5)" Variant="Variant.Outlined">
                                    @for (int n = 1; n <= 5; n++) { var v = n; <MudSelectItem Value="@v">@v</MudSelectItem> }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12"><MudTextField @bind-Value="_newRiskBeskrivning" Label="Beskrivning" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12" sm="4"><MudTextField @bind-Value="_newRiskAtgard" Label="Åtgärd" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12" sm="4"><MudTextField @bind-Value="_newRiskAnsvarig" Label="Ansvarig" Variant="Variant.Outlined" /></MudItem>
                            <MudItem xs="12" sm="4">
                                <MudDatePicker @bind-Date="_newRiskDeadline" Label="Deadline för åtgärd" Variant="Variant.Outlined"
                                               HelperText="När åtgärden senast ska vara klar" />
                            </MudItem>
                        </MudGrid>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SparaRisk"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newRiskNamn))">Spara</MudButton>
                    </MudPaper>
                }

                @* Riskmatris 5×5 — beräknad från DB *@
                <MudText Typo="Typo.h6" Class="mb-2" Style="font-weight: 600;">Riskmatris</MudText>
                <div style="display: grid; grid-template-columns: auto repeat(5, 1fr); gap: 2px; max-width: 500px; margin-bottom: 1rem;">
                    <div></div>
                    @for (int k = 1; k <= 5; k++) { <div style="text-align: center; font-weight: 600; font-size: 0.8rem;">K@k</div> }
                    @for (int s = 5; s >= 1; s--)
                    {
                        <div style="font-weight: 600; font-size: 0.8rem; display: flex; align-items: center;">S@s</div>
                        @for (int k = 1; k <= 5; k++)
                        {
                            var riskVal = s * k;
                            var count = _risks.Count(r => r.Sannolikhet == s && r.Konsekvens == k);
                            var bg = riskVal >= 15 ? "#dc2626" : riskVal >= 10 ? "#f59e0b" : riskVal >= 5 ? "#fbbf24" : "#22c55e";
                            <div style="@($"background: {bg}; color: white; text-align: center; padding: 8px; border-radius: 4px; font-size: 0.8rem; font-weight: {(count > 0 ? "700" : "400")};")">
                                @(count > 0 ? count.ToString() : "")
                            </div>
                        }
                    }
                </div>

                <MudSimpleTable Hover="true" Elevation="1">
                    <thead><tr><th>Risk</th><th>S</th><th>K</th><th>Riskvärde</th><th>Åtgärd</th><th>Ansvarig</th><th>Deadline</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var r in _risks.OrderByDescending(r => r.RiskVarde))
                        {
                            <tr>
                                <td><strong>@r.RiskNamn</strong></td>
                                <td>@r.Sannolikhet</td>
                                <td>@r.Konsekvens</td>
                                <td><MudChip T="string" Size="Size.Small" Color="@RiskVardeFarg(r.RiskVarde)">@r.RiskVarde</MudChip></td>
                                <td>@(r.Atgard ?? "—")</td>
                                <td>@(r.Ansvarig ?? "—")</td>
                                <td>@DeadlineText(r)</td>
                                <td><MudChip T="string" Size="Size.Small" Color="@RiskStatusFarg(r.Status)">@RiskStatusText(r.Status)</MudChip></td>
                                <td>
                                    @if (r.NastaStatus is { } nasta)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.ArrowForward"
                                                   OnClick="@(() => AvanceraRisk(r))">@RiskStatusText(nasta)</MudButton>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </div>
        </MudTabPanel>
    </MudTabs>
}

@code {
    private List<Incident> _incidents = [];
    private List<SafetyRound> _rounds = [];
    private List<RiskAssessment> _risks = [];
    private Dictionary<Guid, string> _enheter = new();
    private bool _loading = true;
    private string? _error;

    // Forms
    private bool _showIncidentForm, _showRoundForm, _showRiskForm;
    private string _newIncRapporterare = "", _newIncPlats = "", _newIncBeskrivning = "", _newIncAtgard = "";
    private Guid _newIncEnhetId;
    private IncidentAllvarlighetsgrad _newIncAllvarlighet = IncidentAllvarlighetsgrad.Medel;
    private IncidentTyp _newIncTyp = IncidentTyp.Tillbud;
    private DateTime? _newRoundDatum = DateTime.Today;
    private Guid _newRoundEnhetId;
    private string _newRoundDeltagare = "";
    private string _newRiskNamn = "", _newRiskBeskrivning = "", _newRiskAtgard = "", _newRiskAnsvarig = "";
    private int _newRiskSannolikhet = 3, _newRiskKonsekvens = 3;
    private DateTime? _newRiskDeadline;

    // Skyddsrond-resultat (inline-redigering)
    private SafetyRound? _roundBeingEdited;
    private int _editBrister;
    private string _editAnteckningar = "";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _incidents = await db.Incidents.ToListAsync();
            _rounds = await db.SafetyRounds.ToListAsync();
            _risks = await db.RiskAssessments.ToListAsync();
            var enheter = await db.OrganizationUnits.ToListAsync();
            _enheter = enheter.ToDictionary(e => e.Id.Value, e => e.Namn);
            if (_enheter.Count > 0) { _newIncEnhetId = _enheter.Keys.First(); _newRoundEnhetId = _enheter.Keys.First(); }
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    /// <summary>
    /// Returnerar enhetsnamn för given Guid. Om EnhetId inte matchar
    /// någon enhet (t.ex. om enheten raderats) visas "Okänd enhet".
    /// </summary>
    private string GetEnhetNamn(Guid enhetId) =>
        _enheter.TryGetValue(enhetId, out var namn) ? namn : "Okänd enhet";

    private async Task SparaIncident()
    {
        if (string.IsNullOrWhiteSpace(_newIncBeskrivning)) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var inc = Incident.Skapa(DateTime.UtcNow, _newIncRapporterare, _newIncEnhetId, _newIncPlats,
            _newIncBeskrivning, _newIncAllvarlighet, _newIncTyp, _newIncAtgard);
        db.Incidents.Add(inc);
        await db.SaveChangesAsync();
        _incidents = await db.Incidents.ToListAsync();
        _showIncidentForm = false;
        _newIncRapporterare = ""; _newIncPlats = ""; _newIncBeskrivning = ""; _newIncAtgard = "";
        _newIncTyp = IncidentTyp.Tillbud; _newIncAllvarlighet = IncidentAllvarlighetsgrad.Medel;
    }

    /// <summary>Flyttar ett ärende ett steg framåt i livscykeln och persisterar.</summary>
    private async Task AvanceraIncident(Incident inc)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var e = await db.Incidents.FirstOrDefaultAsync(x => x.Id == inc.Id);
        if (e is null) return;
        e.FlyttaFram();
        await db.SaveChangesAsync();
        _incidents = await db.Incidents.ToListAsync();
    }

    /// <summary>Återöppnar ett avslutat ärende och persisterar.</summary>
    private async Task AteroppnaIncident(Incident inc)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var e = await db.Incidents.FirstOrDefaultAsync(x => x.Id == inc.Id);
        if (e is null) return;
        e.Ateroppna();
        await db.SaveChangesAsync();
        _incidents = await db.Incidents.ToListAsync();
    }

    private async Task SparaRound()
    {
        if (string.IsNullOrWhiteSpace(_newRoundDeltagare)) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var round = SafetyRound.Skapa(_newRoundDatum?.ToUniversalTime() ?? DateTime.UtcNow, _newRoundEnhetId,
            _newRoundDeltagare, 0, SafetyRoundStatus.Planerad);
        db.SafetyRounds.Add(round);
        await db.SaveChangesAsync();
        _rounds = await db.SafetyRounds.ToListAsync();
        _showRoundForm = false;
        _newRoundDeltagare = "";
    }

    private void OppnaRondResultat(SafetyRound r)
    {
        _roundBeingEdited = r;
        _editBrister = r.AntalBrister;
        _editAnteckningar = r.Anteckningar ?? "";
    }

    /// <summary>Registrerar rondens resultat (antal brister + anteckningar) och persisterar.</summary>
    private async Task GenomforRound()
    {
        if (_roundBeingEdited is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var e = await db.SafetyRounds.FirstOrDefaultAsync(x => x.Id == _roundBeingEdited.Id);
        if (e is null) return;
        e.Genomfor(_editBrister, string.IsNullOrWhiteSpace(_editAnteckningar) ? null : _editAnteckningar);
        await db.SaveChangesAsync();
        _rounds = await db.SafetyRounds.ToListAsync();
        _roundBeingEdited = null;
    }

    /// <summary>Stänger en genomförd rond och persisterar.</summary>
    private async Task AvslutaRound(SafetyRound r)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var e = await db.SafetyRounds.FirstOrDefaultAsync(x => x.Id == r.Id);
        if (e is null) return;
        e.Avsluta();
        await db.SaveChangesAsync();
        _rounds = await db.SafetyRounds.ToListAsync();
    }

    private async Task SparaRisk()
    {
        if (string.IsNullOrWhiteSpace(_newRiskNamn)) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var deadline = _newRiskDeadline.HasValue ? DateOnly.FromDateTime(_newRiskDeadline.Value) : (DateOnly?)null;
        var risk = RiskAssessment.Skapa(_newRiskNamn, _newRiskBeskrivning,
            _newRiskSannolikhet, _newRiskKonsekvens, _newRiskAtgard, _newRiskAnsvarig, deadline);
        db.RiskAssessments.Add(risk);
        await db.SaveChangesAsync();
        _risks = await db.RiskAssessments.ToListAsync();
        _showRiskForm = false;
        _newRiskNamn = ""; _newRiskBeskrivning = ""; _newRiskAtgard = ""; _newRiskAnsvarig = "";
        _newRiskDeadline = null;
    }

    /// <summary>Flyttar en riskbedömning ett steg framåt i åtgärdskedjan och persisterar.</summary>
    private async Task AvanceraRisk(RiskAssessment r)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var e = await db.RiskAssessments.FirstOrDefaultAsync(x => x.Id == r.Id);
        if (e is null) return;
        e.FlyttaFram();
        await db.SaveChangesAsync();
        _risks = await db.RiskAssessments.ToListAsync();
    }

    private async Task LaddaNerIncidenterCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Datum;Rapportör;Enhet;Plats;Allvarlighet;Typ;Status;Åtgärdsförslag");
        foreach (var i in _incidents.OrderByDescending(i => i.Datum))
        {
            sb.AppendLine(string.Join(';', new[]
            {
                i.Datum.ToLocalTime().ToString("yyyy-MM-dd"),
                CsvFalt(i.RapporterareNamn),
                CsvFalt(GetEnhetNamn(i.EnhetId)),
                CsvFalt(i.Plats),
                i.Allvarlighetsgrad.ToString(),
                TypText(i.Typ),
                StatusText(i.Status),
                CsvFalt(i.AtgardsForslag ?? "")
            }));
        }
        await LaddaNerCsv("tillbud-skador.csv", sb.ToString());
    }

    private async Task LaddaNerRiskerCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Risk;Sannolikhet;Konsekvens;Riskvärde;Åtgärd;Ansvarig;Deadline;Status");
        foreach (var r in _risks.OrderByDescending(r => r.RiskVarde))
        {
            sb.AppendLine(string.Join(';', new[]
            {
                CsvFalt(r.RiskNamn),
                r.Sannolikhet.ToString(),
                r.Konsekvens.ToString(),
                r.RiskVarde.ToString(),
                CsvFalt(r.Atgard ?? ""),
                CsvFalt(r.Ansvarig ?? ""),
                r.Deadline?.ToString("yyyy-MM-dd") ?? "",
                RiskStatusText(r.Status)
            }));
        }
        await LaddaNerCsv("riskbedomningar.csv", sb.ToString());
    }

    private async Task LaddaNerCsv(string filnamn, string innehall)
    {
        var bytes = new byte[] { 0xEF, 0xBB, 0xBF }
            .Concat(Encoding.UTF8.GetBytes(innehall)).ToArray();
        await JS.InvokeVoidAsync("downloadFile", filnamn, Convert.ToBase64String(bytes), "text/csv");
    }

    private static string CsvFalt(string v)
    {
        const char q = '\u0022';
        if (v.Contains(';') || v.Contains(q) || v.Contains('\n'))
            return q + v.Replace("\u0022", "\u0022\u0022") + q;
        return v;
    }

    private static string DeadlineText(RiskAssessment r)
    {
        if (r.Deadline is not { } d) return "—";
        var idag = DateOnly.FromDateTime(DateTime.Today);
        var forsenad = idag > d && r.Status != RiskStatus.Atgardad;
        return forsenad ? $"{d:yyyy-MM-dd} (försenad)" : d.ToString("yyyy-MM-dd");
    }

    private static string TypText(IncidentTyp t) => t switch
    {
        IncidentTyp.Tillbud => "Tillbud",
        IncidentTyp.Olycka => "Olycka",
        IncidentTyp.Arbetsskada => "Arbetsskada",
        _ => t.ToString()
    };

    private static string StatusText(IncidentStatus s) => s switch
    {
        IncidentStatus.Rapporterad => "Rapporterad",
        IncidentStatus.UnderUtredning => "Under utredning",
        IncidentStatus.AtgardVidtagen => "Åtgärd vidtagen",
        IncidentStatus.Avslutad => "Avslutad",
        _ => s.ToString()
    };

    private static Color IncidentStatusFarg(IncidentStatus s) => s switch
    {
        IncidentStatus.Rapporterad => Color.Error,
        IncidentStatus.UnderUtredning => Color.Warning,
        IncidentStatus.AtgardVidtagen => Color.Info,
        IncidentStatus.Avslutad => Color.Success,
        _ => Color.Default
    };

    private static string RiskStatusText(RiskStatus s) => s switch
    {
        RiskStatus.Identifierad => "Identifierad",
        RiskStatus.UnderBehandling => "Under behandling",
        RiskStatus.Atgardad => "Åtgärdad",
        _ => s.ToString()
    };

    private static Color RiskStatusFarg(RiskStatus s) => s switch
    {
        RiskStatus.Identifierad => Color.Error,
        RiskStatus.UnderBehandling => Color.Warning,
        RiskStatus.Atgardad => Color.Success,
        _ => Color.Default
    };

    private static Color AllvarlighetFarg(IncidentAllvarlighetsgrad a) => a switch
    {
        IncidentAllvarlighetsgrad.Kritisk => Color.Error,
        IncidentAllvarlighetsgrad.Hog => Color.Warning,
        IncidentAllvarlighetsgrad.Medel => Color.Info,
        _ => Color.Default
    };

    private static Color RondStatusFarg(SafetyRoundStatus s) => s switch
    {
        SafetyRoundStatus.Planerad => Color.Info,
        SafetyRoundStatus.Genomford => Color.Success,
        _ => Color.Default
    };

    private static Color RiskVardeFarg(int v) => v switch
    {
        >= 15 => Color.Error,
        >= 10 => Color.Warning,
        >= 5 => Color.Info,
        _ => Color.Success
    };
}
